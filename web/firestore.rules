    //     || (request.auth != null && request.auth.uid == userId);
    // }
    //
    // match /service_intervals/{document=**} {
    //   allow read: if true;
    //   allow write: if false;
    // }
    //
    // match /mechanics/{document=**} {
    //   allow read: if true;
    //   allow write: if false;
    // }
  }
}
