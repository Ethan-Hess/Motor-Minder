rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY: open rules for local development.
    // Re-enable scoped rules before any non-local deployment.
    match /{document=**} {
      allow read, write: if true;
    }

    // Previous scoped rules:
